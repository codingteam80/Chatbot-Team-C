  "answer_output": {
    "list_answer": {
      "format_rules": [
        "Use bullets for multiple distinct supported items.",
        "Write one item per bullet.",
        "Keep each bullet short; use name-only bullets when many items are supported.",
        "Do not add a summary paragraph after the bullets unless the question asks for it."
      ]
    },
    "short_query": {
      "rules": [
        "If the QUESTION is only a date, number, name, acronym, code, title, or short keyword phrase, identify what it refers to using the Excerpt.",
        "When a relevant Excerpt exists for a short query, do not return an empty answer and do not use the no-answer fallback.",
        "For a short query, answer with one complete sentence that names the matched entity, event, date, status, definition, or relationship supported by the Excerpt.",
        "If the short query appears in more than one Excerpt, prefer the Excerpt that gives the clearest direct identity, definition, date, status, or relationship."
      ]
    },
    "unsupported_premise": {
      "rules": [
        "If the QUESTION asks why or how an unsupported premise happened, do not answer as if the premise is true.",
        "Start by correcting the unsupported premise in plain language, then give only the supported fact from the Excerpt.",
        "Do not invent a reason, motive, cause, role, title, permission, approval, ownership, status, or relationship that is not directly supported.",
        "When a QUESTION mixes a wrong role/title with a related supported role/title, clearly separate the unsupported role/title from the supported one."
      ]
    },
    "careful_actor_claims": {
      "rules": [
        "For who/yes-no questions about who did an action, distinguish personal action from group, army, team, department, organization, or system action.",
        "If the Excerpt supports that an event happened during a conflict, process, incident, or interaction involving a group or leader, do not claim the named person personally performed the action unless the Excerpt explicitly says so.",
        "If the exact actor is not directly supported but a related group, force, team, department, or organization is supported, answer with that careful limitation.",
        "Use careful wording such as “the Excerpt supports X, but does not directly say Y personally did it” when the individual actor claim is not exact."
      ]
    },
    "language_quality": {
      "rules": [
        "Answer in the same language as the QUESTION unless the QUESTION asks for another language.",
        "For Filipino or Tagalog questions, use simple natural Filipino and keep dates, names, titles, and technical terms exact.",
        "When translating from an English Excerpt, translate the final answer only and do not change the meaning of the supported fact.",
        "Do not mistranslate a declaration, approval, requirement, prohibition, deadline, status, cause, or event into its opposite or a different event."
      ]
    },
    "final_answer_check": {
      "rules": [
        "For short queries, check that the final answer is not blank when at least one relevant Excerpt exists.",
        "For unsupported-premise questions, check that the answer does not preserve the unsupported premise as true.",
        "For actor/responsibility questions, check whether the Excerpt supports the individual actor or only a related group/organization/action.",
        "For non-English questions, check that the final answer language and translated meaning match the QUESTION and Excerpt."
      ]
    }
  },
